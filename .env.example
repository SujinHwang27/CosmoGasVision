# Copy to .env and fill in values. .env is gitignored.

# MLflow tracking server — local (see scripts/start_mlflow.ps1)
MLFLOW_TRACKING_URI=http://127.0.0.1:5000

# Override the host/port the local MLflow server binds to.
# Default: 127.0.0.1:5000 (loopback only). Set MLFLOW_HOST=0.0.0.0 to expose on LAN.
# MLFLOW_HOST=127.0.0.1
# MLFLOW_PORT=5000

# AWS credentials for DVC S3 remote (s3://cosmo-gas-vision-storage/dvc-data)
# and MLflow S3 artifact root (s3://cosmo-gas-vision-storage/mlflow-artifacts).
# The MLflow server process needs these — not just the client.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1


# Juno HPC — paths follow the UTD top-level convention: /work and
# /scratch/juno are NOT under /home. See .claude/skills/juno-hpc/SKILL.md.
JUNO_NETID=<your-netid>
JUNO_HOST=juno.utdallas.edu
JUNO_WORK=/work/<your-netid>/CosmoGasVision
JUNO_SCRATCH=/scratch/juno/<your-netid>
