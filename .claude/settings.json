{
  "permissions": {
    "allow": [
      "Bash(uv run:*)",
      "Bash(uv add:*)",
      "Bash(uv sync:*)",
      "Bash(uv pip:*)",
      "Bash(uv lock:*)",
      "Bash(dvc status:*)",
      "Bash(dvc list:*)",
      "Bash(dvc remote:*)",
      "Bash(dvc push:*)",
      "Bash(dvc pull:*)",
      "Bash(dvc add:*)",
      "Bash(dvc diff:*)",
      "Bash(mlflow ui:*)",
      "Bash(python -u:*)",
      "Bash(python -m:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git ls-files:*)",
      "Bash(ruff:*)",
      "Bash(black:*)"
    ],
    "deny": [
      "Write(Sherwood/**)",
      "Edit(Sherwood/**)",
      "Write(SherwoodIGM_gal/*.dat)",
      "Edit(SherwoodIGM_gal/*.dat)",
      "Write(SherwoodIGM_gal/*.h5)",
      "Edit(SherwoodIGM_gal/*.h5)",
      "Write(SherwoodIGM_gal/*.hdf5)",
      "Edit(SherwoodIGM_gal/*.hdf5)",
      "Write(SherwoodIGM_gal/*.tar.gz)",
      "Edit(SherwoodIGM_gal/*.tar.gz)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "if [ -n \"$(find papers/shared/sec papers/shared/numbers.tex papers/shared/main.bib papers/cvpr2026/main.tex papers/cvpr2026/preamble.tex -newer papers/cvpr2026/main.pdf 2>/dev/null)\" ] || [ ! -f papers/cvpr2026/main.pdf ]; then cd papers/cvpr2026 && latexmk -pdf -interaction=nonstopmode main.tex >/tmp/latexmk-stop.log 2>&1 || { echo 'papers/cvpr2026 build FAILED (last 20 lines):' >&2; tail -20 /tmp/latexmk-stop.log >&2; }; fi; exit 0",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
