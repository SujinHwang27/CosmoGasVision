# General Exclusions
__pycache__/
*.py[cod]
*$py.class
*.so

# Personal Claude Code memory (per-machine; never tracked)
.claude-memory/

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Hidden project folders (DVC/Environment)
# We ignore ALL folders starting with a dot in Git
# except for the ones needed for repo operation
.*/
!.gitignore
!.github/
!.claude/
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Specific files to ignore
.env

# Large simulation volumes — NOT DVC-tracked (too large to host on the team
# remote; load directly from the upstream Sherwood S3 bucket when needed).
Sherwood/
SherwoodIGM_gal/

# Disk cache for CIC-deposited rho/<rho> 3D fields (Sprint-1 [D-46]/[D-47]
# Stage 3 infra). Regenerable from the sim binaries above; per the same
# precedent it is neither git- nor DVC-tracked.
Sherwood/.rho_field_cache/

# Experiments: track source (LEDGER.md, pipeline.py, configs); DVC-track artifacts
experiments/**/artifacts/
experiments/**/__pycache__/

# MLflow
mlruns/
mlflow.db

# DVC internals
.dvc/tmp/
.dvc/cache/
/.docs
/.overleaf_mcp
/docs

# Per [D-45] master-source architecture: paper source (.tex, .bib, .sty, figures<10MB)
# is git-tracked; build artifacts are not. Old /paper_cvpr DVC tracking retired
# at HEAD ff4b951+.
papers/**/main.aux
papers/**/main.bbl
papers/**/main.blg
papers/**/main.brf
papers/**/main.fdb_latexmk
papers/**/main.fls
papers/**/main.log
papers/**/main.out
papers/**/main.pdf
papers/**/main.synctex.gz
papers/**/main.toc
papers/**/_minted-main/
